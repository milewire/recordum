# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=recordum

# LLM (advisory only)
# AI_PROVIDER options: anthropic | ollama | hybrid
# "hybrid" uses Ollama by default and falls back to Claude if Ollama is down
AI_PROVIDER=ollama
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Docker: http://host.docker.internal:11434 — local dev: http://localhost:11434
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3:4b

# Postgres
POSTGRES_DSN=postgresql://localhost:5432/recordum

# API
API_HOST=0.0.0.0
API_PORT=8000
